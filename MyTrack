<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BET TRACKER</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Barlow+Condensed:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #050505;
    --surface:  #0e0e0e;
    --border:   #1a1a1a;
    --border2:  #222;
    --green:    #00e676;
    --green2:   #00c853;
    --green-dim:#003d1a;
    --red:      #ff3d3d;
    --red-dim:  #3d0000;
    --yellow:   #ffd600;
    --text:     #f0f0f0;
    --muted:    #555;
    --muted2:   #333;
    --mono:     'DM Mono', monospace;
    --display:  'Barlow Condensed', sans-serif;
  }

  html, body { min-height: 100vh; background: var(--bg); color: var(--text); font-family: var(--mono); }

  /* ── Layout ── */
  .app { max-width: 780px; margin: 0 auto; padding: 24px 16px 80px; }

  /* ── Header ── */
  .header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 28px; border-bottom: 1px solid var(--border2); padding-bottom: 16px; }
  .header-title { font-family: var(--display); font-size: 42px; font-weight: 900; letter-spacing: 0.04em; line-height: 1; color: var(--green); text-transform: uppercase; }
  .header-sub { font-size: 11px; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; margin-top: 4px; }
  .header-actions { display: flex; gap: 8px; align-items: center; }

  /* ── Buttons ── */
  .btn { font-family: var(--mono); font-size: 11px; font-weight: 500; letter-spacing: 0.08em; border: 1px solid var(--border2); background: var(--surface); color: var(--muted); padding: 8px 14px; border-radius: 6px; cursor: pointer; transition: all 0.15s; text-transform: uppercase; }
  .btn:hover { border-color: var(--green); color: var(--green); }
  .btn-green { background: var(--green); color: #000; border-color: var(--green); font-weight: 700; }
  .btn-green:hover { background: var(--green2); border-color: var(--green2); color: #000; }
  .btn-danger { border-color: var(--red-dim); color: var(--red); }
  .btn-danger:hover { background: var(--red-dim); }

  /* ── Dashboard ── */
  .dashboard { margin-bottom: 24px; }
  .period-tabs { display: flex; gap: 4px; margin-bottom: 12px; }
  .period-tab { font-family: var(--display); font-size: 13px; font-weight: 700; letter-spacing: 0.06em; padding: 6px 14px; border-radius: 4px; border: 1px solid var(--border2); background: transparent; color: var(--muted); cursor: pointer; transition: all 0.15s; text-transform: uppercase; }
  .period-tab.active { background: var(--green-dim); border-color: var(--green); color: var(--green); }

  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 8px; }
  .stats-grid-2 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 8px; }
  .stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 12px; text-align: center; }
  .stat-label { font-size: 9px; letter-spacing: 0.14em; color: var(--muted); text-transform: uppercase; margin-bottom: 6px; }
  .stat-val { font-family: var(--display); font-size: 22px; font-weight: 800; letter-spacing: 0.02em; }
  .stat-val.pos { color: var(--green); }
  .stat-val.neg { color: var(--red); }
  .stat-val.neu { color: var(--muted); }

  /* ── Tag breakdown ── */
  .tag-breakdown { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 14px; margin-bottom: 8px; }
  .tag-breakdown-title { font-size: 9px; letter-spacing: 0.14em; color: var(--muted); text-transform: uppercase; margin-bottom: 10px; }
  .tag-row { display: flex; align-items: center; gap: 10px; padding: 5px 0; border-bottom: 1px solid var(--border); font-size: 12px; }
  .tag-row:last-child { border-bottom: none; }
  .tag-name { flex: 1; color: var(--green); font-weight: 500; }
  .tag-wl { color: var(--text); min-width: 50px; }
  .tag-pl { min-width: 70px; text-align: right; }
  .tag-pl.pos { color: var(--green); }
  .tag-pl.neg { color: var(--red); }
  .tag-empty { color: var(--muted); font-size: 11px; text-align: center; padding: 8px; }

  /* ── Input section ── */
  .input-section { background: var(--surface); border: 1px solid var(--border2); border-radius: 10px; padding: 16px; margin-bottom: 20px; }
  .input-row { display: flex; gap: 8px; margin-bottom: 10px; }
  .bet-input { flex: 1; background: var(--bg); border: 1px solid var(--border2); border-radius: 6px; padding: 10px 12px; color: var(--text); font-family: var(--mono); font-size: 13px; font-weight: 500; resize: none; outline: none; transition: border-color 0.15s; }
  .bet-input:focus { border-color: var(--green); }
  .bet-input::placeholder { color: var(--muted); }
  .tag-input-row { display: flex; gap: 8px; align-items: center; }
  .tag-input { flex: 1; background: var(--bg); border: 1px solid var(--border2); border-radius: 6px; padding: 8px 12px; color: var(--green); font-family: var(--mono); font-size: 12px; outline: none; transition: border-color 0.15s; }
  .tag-input:focus { border-color: var(--green); }
  .tag-input::placeholder { color: var(--muted); }
  .tag-suggestions { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 8px; }
  .tag-suggestion { font-size: 10px; padding: 3px 8px; border-radius: 3px; background: var(--green-dim); color: var(--green); border: 1px solid #005c1f; cursor: pointer; letter-spacing: 0.06em; }
  .tag-suggestion:hover { background: #005c1f; }

  /* ── Date row ── */
  .date-row { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .date-label { font-size: 10px; letter-spacing: 0.1em; color: var(--muted); text-transform: uppercase; }
  .date-input { background: var(--bg); border: 1px solid var(--border2); border-radius: 6px; padding: 7px 10px; color: var(--text); font-family: var(--mono); font-size: 12px; outline: none; cursor: pointer; }
  .date-input:focus { border-color: var(--green); }

  /* ── Bets list ── */
  .bets-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .bets-title { font-family: var(--display); font-size: 16px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text); }
  .bets-count { font-size: 11px; color: var(--green); margin-left: 8px; font-weight: 500; }
  .bets-actions { display: flex; gap: 6px; }

  .bet-item { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 12px 14px; margin-bottom: 8px; transition: border-color 0.15s; }
  .bet-item:hover { border-color: var(--border2); }
  .bet-item.graded-win  { border-left: 3px solid var(--green); }
  .bet-item.graded-loss { border-left: 3px solid var(--red); }
  .bet-item.graded-push { border-left: 3px solid var(--yellow); }

  .bet-top { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 8px; }
  .bet-text { flex: 1; font-size: 13px; font-weight: 500; line-height: 1.5; color: var(--text); }
  .bet-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
  .bet-tag { font-size: 9px; padding: 2px 7px; border-radius: 3px; background: var(--green-dim); color: var(--green); border: 1px solid #004d17; letter-spacing: 0.07em; text-transform: uppercase; }
  .bet-date-str { font-size: 10px; color: var(--muted); margin-bottom: 8px; }

  .bet-actions { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .bet-btn { font-family: var(--mono); font-size: 10px; padding: 4px 10px; border-radius: 4px; border: 1px solid var(--border2); background: transparent; color: var(--muted); cursor: pointer; transition: all 0.15s; text-transform: uppercase; letter-spacing: 0.06em; }
  .bet-btn:hover { border-color: var(--green); color: var(--green); }
  .bet-btn.delete:hover { border-color: var(--red); color: var(--red); }

  /* ── Grade badge ── */
  .grade-badge { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 4px; font-size: 11px; font-weight: 700; letter-spacing: 0.05em; }
  .grade-win  { background: #002910; border: 1px solid var(--green); color: var(--green); }
  .grade-loss { background: var(--red-dim); border: 1px solid var(--red); color: var(--red); }
  .grade-push { background: #2a2000; border: 1px solid var(--yellow); color: var(--yellow); }
  .grade-err  { background: var(--border); border: 1px solid var(--muted2); color: var(--muted); }

  .manual-grade-btns { display: inline-flex; gap: 4px; }
  .mgb { font-family: var(--mono); font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 4px; border: none; cursor: pointer; letter-spacing: 0.06em; }
  .mgb-w { background: var(--green); color: #000; }
  .mgb-l { background: var(--red); color: #fff; }
  .mgb-p { background: var(--yellow); color: #000; }

  /* ── Grade All btn ── */
  .grade-all-btn { width: 100%; padding: 11px; border-radius: 8px; border: 1px solid #1a3a1a; background: #0a1a0a; color: var(--green); font-family: var(--display); font-size: 15px; font-weight: 800; letter-spacing: 0.1em; cursor: pointer; text-transform: uppercase; transition: all 0.15s; margin-bottom: 16px; }
  .grade-all-btn:hover { background: var(--green-dim); border-color: var(--green); }

  /* ── Empty state ── */
  .empty { text-align: center; padding: 40px 20px; color: var(--muted); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; border: 1px dashed var(--border2); border-radius: 8px; }

  /* ── Filter bar ── */
  .filter-bar { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 14px; align-items: center; }
  .filter-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-right: 2px; }
  .filter-tag { font-size: 10px; padding: 3px 10px; border-radius: 3px; border: 1px solid var(--border2); background: transparent; color: var(--muted); cursor: pointer; letter-spacing: 0.06em; text-transform: uppercase; transition: all 0.12s; }
  .filter-tag.active { background: var(--green-dim); border-color: var(--green); color: var(--green); }

  /* ── Summary copy box ── */
  .summary-box { background: var(--surface); border: 1px solid var(--border2); border-radius: 8px; padding: 14px; margin-bottom: 20px; }
  .summary-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .summary-label { font-size: 10px; letter-spacing: 0.14em; color: var(--muted); text-transform: uppercase; }
  .summary-text { font-size: 14px; font-weight: 500; line-height: 1.8; }
  .summary-text .line1 { color: var(--text); }
  .summary-text .line2 { color: var(--green); font-weight: 700; }

  /* ── Bet type selector ── */
  .type-row { display: flex; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; align-items: center; }
  .type-label { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin-right: 2px; }
  .type-btn { font-family: var(--mono); font-size: 10px; padding: 4px 11px; border-radius: 4px; border: 1px solid var(--border2); background: transparent; color: var(--muted); cursor: pointer; letter-spacing: 0.06em; text-transform: uppercase; transition: all 0.12s; }
  .type-btn.active { background: var(--green-dim); border-color: var(--green); color: var(--green); }
  .stat-pill { font-size: 10px; padding: 2px 8px; border-radius: 3px; background: #0a1f0a; border: 1px solid #1a3a1a; color: #00c853; letter-spacing: 0.07em; text-transform: uppercase; font-weight: 500; }

  /* ── File IO ── */
  #fileInput { display: none; }

  /* ── Scrollbar ── */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }
</style>
</head>
<body>
<div class="app">

  <!-- Header -->
  <div class="header">
    <div>
      <div class="header-title">BET TRACKER</div>
      <div class="header-sub">Personal · NBA · 2025-26</div>
    </div>
    <div class="header-actions">
      <button class="btn" onclick="loadFromFile()">↑ LOAD</button>
      <button class="btn" onclick="saveToFile()">↓ SAVE</button>
      <input type="file" id="fileInput" accept=".json" onchange="handleFileLoad(event)">
    </div>
  </div>

  <!-- Dashboard -->
  <div class="dashboard">
    <div class="period-tabs">
      <button class="period-tab active" onclick="setPeriod('all',this)">All Time</button>
      <button class="period-tab" onclick="setPeriod('month',this)">Month</button>
      <button class="period-tab" onclick="setPeriod('week',this)">Week</button>
      <button class="period-tab" onclick="setPeriod('day',this)">Today</button>
    </div>
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-label">W-L</div><div class="stat-val neu" id="dWL">—</div></div>
      <div class="stat-card"><div class="stat-label">Units +/-</div><div class="stat-val neu" id="dPL">—</div></div>
      <div class="stat-card"><div class="stat-label">Win Rate</div><div class="stat-val neu" id="dWR">—</div></div>
      <div class="stat-card"><div class="stat-label">ROI</div><div class="stat-val neu" id="dROI">—</div></div>
    </div>
    <div class="stats-grid-2">
      <div class="stat-card"><div class="stat-label">Bets</div><div class="stat-val neu" id="dBets">—</div></div>
      <div class="stat-card"><div class="stat-label">Avg Odds</div><div class="stat-val neu" id="dOdds">—</div></div>
      <div class="stat-card"><div class="stat-label">Longest Win Streak</div><div class="stat-val neu" id="dStreak">—</div></div>
    </div>
    <div class="tag-breakdown" id="tagBreakdown">
      <div class="tag-breakdown-title">By Tag</div>
      <div class="tag-empty" id="tagEmpty">No tagged bets yet</div>
    </div>
  </div>

  <!-- Summary copy -->
  <div class="summary-box" id="summaryBox" style="display:none">
    <div class="summary-header">
      <div class="summary-label">Summary</div>
      <button class="btn" id="copyBtn" onclick="copySummary()">COPY</button>
    </div>
    <div class="summary-text" id="summaryText"></div>
  </div>

  <!-- Input -->
  <div class="input-section">
    <div class="date-row">
      <span class="date-label">Date</span>
      <input type="date" class="date-input" id="betDate">
    </div>
    <div class="type-row">
      <span class="type-label">Type:</span>
      <button class="type-btn active" onclick="setBetType('prop',this)">Prop</button>
      <button class="type-btn" onclick="setBetType('total',this)">Total</button>
      <button class="type-btn" onclick="setBetType('ml',this)">ML</button>
      <button class="type-btn" onclick="setBetType('spread',this)">Spread</button>
      <button class="type-btn" onclick="setBetType('parlay',this)">Parlay</button>
      <button class="type-btn" onclick="setBetType('sgp',this)">SGP</button>
    </div>
    <div class="input-row">
      <textarea class="bet-input" id="betInput" rows="2" placeholder="Type your bet... e.g. LeBron James Lakers over 25.5 pts -110 FanDuel good to -115" autocorrect="off" autocapitalize="off" spellcheck="false" onkeydown="handleBetKey(event)"></textarea>
    </div>
    <div class="tag-input-row">
      <input type="text" class="tag-input" id="tagInput" placeholder="tags (comma separated)... e.g. player prop, value" autocorrect="off" autocapitalize="off" spellcheck="false">
      <button class="btn btn-green" onclick="addBet()">+ ADD</button>
    </div>
    <div class="tag-suggestions" id="tagSuggestions"></div>
  </div>

  <!-- Bets list -->
  <div class="bets-header">
    <div>
      <span class="bets-title">Bets</span>
      <span class="bets-count" id="betsCount"></span>
    </div>
    <div class="bets-actions">
      <button class="btn btn-danger" onclick="clearAllBets()">CLEAR ALL</button>
    </div>
  </div>

  <button class="grade-all-btn" onclick="gradeAll(this)">⚡ GRADE ALL</button>

  <!-- Filter -->
  <div class="filter-bar" id="filterBar"></div>

  <div id="betsList"></div>

</div>

<script>
// ── State ────────────────────────────────────────────────────────────
let bets = [];         // { id, text, tags, date, grade, odds, actual, betType, statType }
let currentBetType = 'prop';
let activePeriod = 'all';
let activeFilter  = null;
const API_KEY = '9cdb249f-9635-4cca-a998-37c7b98a9372';

// ── Init ─────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  loadFromStorage();
  initDate();
  render();
});

function initDate() {
  const el = document.getElementById('betDate');
  const today = new Date().toISOString().split('T')[0];
  el.value = today;
}

// ── Storage ──────────────────────────────────────────────────────────
function loadFromStorage() {
  try { bets = JSON.parse(localStorage.getItem('bt_bets') || '[]'); } catch(e) { bets = []; }
}
function saveToStorage() {
  localStorage.setItem('bt_bets', JSON.stringify(bets));
}

// ── File IO ──────────────────────────────────────────────────────────
function saveToFile() {
  const data = { version: 1, exported: new Date().toISOString(), bets };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `bet-tracker-${new Date().toISOString().split('T')[0]}.json`;
  a.click();
}
function loadFromFile() { document.getElementById('fileInput').click(); }
function handleFileLoad(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = evt => {
    try {
      const data = JSON.parse(evt.target.result);
      if (data.bets) {
        bets = data.bets;
        saveToStorage();
        render();
      }
    } catch(err) { alert('Invalid file'); }
  };
  reader.readAsText(file);
  e.target.value = '';
}

// ── Input ────────────────────────────────────────────────────────────
// ── Bet type ─────────────────────────────────────────────────────────
function setBetType(type, btn) {
  currentBetType = type;
  document.querySelectorAll('.type-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

function detectStatType(text) {
  const t = text.toLowerCase();
  if (/points rebounds assists|\bpra\b/.test(t)) return 'pra';
  if (/3-pointers made|\b3pm\b/.test(t)) return '3pm';
  if (/\bpoints\b/.test(t)) return 'pts';
  if (/\brebounds\b/.test(t)) return 'reb';
  if (/\bassists\b/.test(t)) return 'ast';
  if (/\bsteals\b/.test(t)) return 'stl';
  if (/\bblocks\b/.test(t)) return 'blk';
  if (/\bminutes\b/.test(t)) return 'min';
  if (/\bturnovers\b/.test(t)) return 'tov';
  return null;
}

// ── Shorthands ───────────────────────────────────────────────────────
const EXPANSIONS = {
  'pts': 'points', 'reb': 'rebounds', 'ast': 'assists',
  'pra': 'points rebounds assists', 'stl': 'steals', 'blk': 'blocks',
  '3pm': '3-pointers made', 'min': 'minutes', 'fg': 'field goals',
  'fd': 'FanDuel', 'pb': 'Builder', 'bm': 'Bookmaker',
  'onyx': 'Onyx', 'px': 'ProphetX', 'novig': 'Novig', 'nv': 'Novig',
  'fliff': 'Fliff', 'dk': 'DraftKings', 'mgm': 'BetMGM',
  'czr': 'Caesars', 'hard': 'HardRock', 'bet365': 'bet365',
  'pin': 'Pinnacle', 'pinnacle': 'Pinnacle', 'circa': 'Circa',
  'bov': 'Bovada', 'bovada': 'Bovada',
};

function expandShorthands(text) {
  // u2.5 → under 2.5, o22.5 → over 22.5
  text = text.replace(/\bo([0-9]+(?:\.[0-9]+)?)/gi, 'over $1');
  text = text.replace(/\bu([0-9]+(?:\.[0-9]+)?)/gi, 'under $1');
  // bare positive odds: 110 → +110
  text = text.replace(/(^|\s)(1[0-9]{2,}|[2-9][0-9]{2,})(?=\s|$)/g, '$1+$2');
  // stat/book expansions
  const expKeys = Object.keys(EXPANSIONS).sort((a,b) => b.length - a.length).join('|');
  const expRegex = new RegExp('\\b(' + expKeys + ')\\b', 'gi');
  text = text.replace(expRegex, w => EXPANSIONS[w.toLowerCase()] || w);
  return text;
}

function handleBetKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); addBet(); }
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('betInput').addEventListener('input', function(e) {
    if (e.data === ' ') {
      const ta = this;
      const pos = ta.selectionStart;
      const before = ta.value;
      const expanded = expandShorthands(before);
      if (expanded !== before) {
        const diff = expanded.length - before.length;
        ta.value = expanded;
        ta.selectionStart = ta.selectionEnd = pos + diff;
      }
    }
  });
});

function addBet() {
  const text = document.getElementById('betInput').value.trim();
  if (!text) return;
  const tagRaw = document.getElementById('tagInput').value.trim();
  const tags = tagRaw ? tagRaw.split(',').map(t => t.trim().toLowerCase()).filter(Boolean) : [];
  const date = document.getElementById('betDate').value;
  const odds = extractFirstOdds(text);

  const statType = currentBetType === 'prop' ? detectStatType(text) : null;
  bets.unshift({ id: Date.now(), text, tags, date, grade: null, odds, actual: null, betType: currentBetType, statType });
  saveToStorage();
  document.getElementById('betInput').value = '';
  document.getElementById('tagInput').value = '';
  render();
}

// ── Tags ─────────────────────────────────────────────────────────────
function getAllTags() {
  const set = new Set();
  bets.forEach(b => b.tags.forEach(t => set.add(t)));
  return [...set].sort();
}

function updateTagSuggestions() {
  const tags = getAllTags();
  const el = document.getElementById('tagSuggestions');
  if (!tags.length) { el.innerHTML = ''; return; }
  el.innerHTML = tags.map(t =>
    `<span class="tag-suggestion" onclick="useTag('${t}')">${t}</span>`
  ).join('');
}

function useTag(tag) {
  const el = document.getElementById('tagInput');
  const cur = el.value.trim();
  const parts = cur ? cur.split(',').map(x => x.trim()) : [];
  if (!parts.includes(tag)) parts.push(tag);
  el.value = parts.join(', ');
}

// ── Period filter ────────────────────────────────────────────────────
function setPeriod(p, btn) {
  activePeriod = p;
  document.querySelectorAll('.period-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  render();
}

function inPeriod(bet) {
  if (activePeriod === 'all') return true;
  const d = new Date(bet.date + 'T12:00:00');
  const now = new Date();
  if (activePeriod === 'day') return bet.date === now.toISOString().split('T')[0];
  if (activePeriod === 'week') {
    const weekAgo = new Date(now); weekAgo.setDate(now.getDate() - 7);
    return d >= weekAgo;
  }
  if (activePeriod === 'month') {
    return d.getMonth() === now.getMonth() && d.getFullYear() === now.getFullYear();
  }
  return true;
}

// ── Units math ───────────────────────────────────────────────────────
function extractFirstOdds(text) {
  const m = text.match(/(?<!\d)([+-](?:1[0-9]{2,3}|[2-9][0-9]{2,3}))(?!\d)/);
  return m ? parseInt(m[1]) : null;
}

function calcPL(odds, result) {
  if (result === 'push') return 0;
  if (!odds) return result === 'win' ? 1 : -1;
  if (odds > 0) return result === 'win' ? +(odds / 100).toFixed(3) : -1;
  const risk = +(Math.abs(odds) / 100).toFixed(3);
  return result === 'win' ? 1 : -risk;
}

function fmtPL(v) { return (v >= 0 ? '+' : '') + v.toFixed(2) + 'u'; }
function fmtOdds(o) { return o > 0 ? '+' + o : '' + o; }

// ── Dashboard ────────────────────────────────────────────────────────
function updateDashboard() {
  const filtered = bets.filter(b => inPeriod(b) && (!activeFilter || b.tags.includes(activeFilter)));
  const graded   = filtered.filter(b => b.grade === 'win' || b.grade === 'loss' || b.grade === 'push');
  const wins     = graded.filter(b => b.grade === 'win').length;
  const losses   = graded.filter(b => b.grade === 'loss').length;
  const total    = wins + losses;
  const pl       = graded.reduce((s, b) => s + calcPL(b.odds, b.grade), 0);
  const wr       = total ? (wins / total * 100).toFixed(1) + '%' : '—';
  const risk     = graded.reduce((s, b) => {
    if (!b.odds) return s + 1;
    return s + (b.odds < 0 ? Math.abs(b.odds) / 100 : 1);
  }, 0);
  const roi      = risk ? (pl / risk * 100).toFixed(1) + '%' : '—';

  // Avg odds
  const oddsArr = graded.filter(b => b.odds).map(b => b.odds);
  const avgOdds = oddsArr.length ? Math.round(oddsArr.reduce((a,b) => a+b,0)/oddsArr.length) : null;

  // Win streak
  const sorted = [...graded].sort((a,b) => new Date(a.date) - new Date(b.date));
  let streak = 0, maxStreak = 0, cur = 0;
  sorted.forEach(b => { if (b.grade === 'win') { cur++; maxStreak = Math.max(maxStreak, cur); } else { cur = 0; } });

  const set = (id, val, cls) => {
    const el = document.getElementById(id);
    el.textContent = val;
    el.className = 'stat-val ' + (cls || 'neu');
  };

  set('dWL', total ? `${wins}-${losses}` : '—', total ? (wins >= losses ? 'pos' : 'neg') : 'neu');
  const plCls = pl > 0 ? 'pos' : pl < 0 ? 'neg' : 'neu';
  set('dPL', graded.length ? fmtPL(pl) : '—', plCls);
  set('dWR', wr, total ? (wins/total >= 0.5 ? 'pos' : 'neg') : 'neu');
  set('dROI', roi, roi !== '—' ? (parseFloat(roi) >= 0 ? 'pos' : 'neg') : 'neu');
  set('dBets', filtered.length || '—', 'neu');
  set('dOdds', avgOdds ? fmtOdds(avgOdds) : '—', avgOdds ? (avgOdds >= 0 ? 'pos' : 'neu') : 'neu');
  set('dStreak', maxStreak || '—', maxStreak ? 'pos' : 'neu');

  // Tag breakdown
  updateTagBreakdown(filtered);
  updateStatBreakdown(filtered);
  updateSummary(wins, losses, pl);
}

function updateTagBreakdown(filtered) {
  const tags = getAllTags();
  const el = document.getElementById('tagBreakdown');
  const empty = document.getElementById('tagEmpty');

  if (!tags.length) { empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  // Remove old rows
  el.querySelectorAll('.tag-row').forEach(r => r.remove());

  tags.forEach(tag => {
    const tagBets = filtered.filter(b => b.tags.includes(tag) && (b.grade === 'win' || b.grade === 'loss' || b.grade === 'push'));
    if (!tagBets.length) return;
    const w = tagBets.filter(b => b.grade === 'win').length;
    const l = tagBets.filter(b => b.grade === 'loss').length;
    const pl = tagBets.reduce((s, b) => s + calcPL(b.odds, b.grade), 0);
    const row = document.createElement('div');
    row.className = 'tag-row';
    row.innerHTML = `<span class="tag-name">#${tag}</span><span class="tag-wl">${w}-${l}</span><span class="tag-pl ${pl >= 0 ? 'pos' : 'neg'}">${fmtPL(pl)}</span>`;
    el.appendChild(row);
  });
}

function updateStatBreakdown(filtered) {
  const statLabels = { pts:'Points', reb:'Rebounds', ast:'Assists', pra:'PRA', '3pm':'3PM', stl:'Steals', blk:'Blocks', min:'Minutes', tov:'Turnovers' };
  const el = document.getElementById('tagBreakdown');

  // Remove old stat rows
  el.querySelectorAll('.stat-type-row').forEach(r => r.remove());

  const statTotals = {};
  filtered.forEach(b => {
    if (!b.statType) return;
    if (!statTotals[b.statType]) statTotals[b.statType] = { w:0, l:0, pl:0 };
    if (b.grade === 'win') { statTotals[b.statType].w++; statTotals[b.statType].pl += calcPL(b.odds, 'win'); }
    else if (b.grade === 'loss') { statTotals[b.statType].l++; statTotals[b.statType].pl += calcPL(b.odds, 'loss'); }
    else if (b.grade === 'push') {}
  });

  if (!Object.keys(statTotals).length) return;

  // Add divider
  const divider = document.createElement('div');
  divider.className = 'stat-type-row';
  divider.style.cssText = 'font-size:9px;letter-spacing:0.12em;color:var(--muted);text-transform:uppercase;padding:8px 0 4px;border-bottom:1px solid var(--border);';
  divider.textContent = 'By Stat';
  el.appendChild(divider);

  Object.entries(statTotals).forEach(([stat, d]) => {
    const row = document.createElement('div');
    row.className = 'tag-row stat-type-row';
    row.innerHTML = `<span class="tag-name">${statLabels[stat] || stat}</span><span class="tag-wl">${d.w}-${d.l}</span><span class="tag-pl ${d.pl >= 0 ? 'pos' : 'neg'}">${fmtPL(d.pl)}</span>`;
    el.appendChild(row);
  });
}

function updateSummary(wins, losses, pl) {
  const box = document.getElementById('summaryBox');
  const txt = document.getElementById('summaryText');
  if (!(wins + losses)) { box.style.display = 'none'; return; }
  box.style.display = 'block';
  const periodLabel = { all: 'All Time', month: 'This Month', week: 'This Week', day: 'Today' }[activePeriod];
  txt.innerHTML = `<div class="line1">${periodLabel} ${wins}-${losses} ${fmtPL(pl)}</div><div class="line2">Personal Record</div>`;
}

function copySummary() {
  const txt = document.getElementById('summaryText');
  const lines = [...txt.querySelectorAll('div')].map(d => d.textContent).join('\n');
  navigator.clipboard.writeText(lines).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✓ COPIED';
    setTimeout(() => btn.textContent = 'COPY', 1800);
  });
}

// ── Filter bar ───────────────────────────────────────────────────────
function updateFilterBar() {
  const tags = getAllTags();
  const bar = document.getElementById('filterBar');
  if (!tags.length) { bar.innerHTML = ''; return; }
  bar.innerHTML = `<span class="filter-label">Filter:</span>` +
    `<span class="filter-tag ${!activeFilter ? 'active' : ''}" onclick="setFilter(null)">All</span>` +
    tags.map(t => `<span class="filter-tag ${activeFilter === t ? 'active' : ''}" onclick="setFilter('${t}')">#${t}</span>`).join('');
}

function setFilter(tag) {
  activeFilter = tag;
  render();
}

// ── Render ───────────────────────────────────────────────────────────
function render() {
  updateTagSuggestions();
  updateDashboard();
  updateFilterBar();
  renderBets();
}

function renderBets() {
  const list = document.getElementById('betsList');
  const count = document.getElementById('betsCount');
  const filtered = bets.filter(b => !activeFilter || b.tags.includes(activeFilter));

  count.textContent = filtered.length ? `(${filtered.length})` : '';

  if (!filtered.length) {
    list.innerHTML = '<div class="empty">No bets yet — add one above</div>';
    return;
  }

  list.innerHTML = filtered.map((bet, idx) => {
    const realIdx = bets.indexOf(bet);
    const gradeClass = bet.grade ? `graded-${bet.grade}` : '';
    const badgeHtml = buildBadge(bet, realIdx);
    const tagsHtml = bet.tags.length ? `<div class="bet-tags">${bet.tags.map(t => `<span class="bet-tag">#${t}</span>`).join('')}</div>` : '';
    const dateStr = formatDate(bet.date);
    const betTypeLabel = { prop:'PROP', total:'TOTAL', ml:'ML', spread:'SPREAD', parlay:'PARLAY', sgp:'SGP' }[bet.betType] || '';
    const statLabel = { pts:'PTS', reb:'REB', ast:'AST', pra:'PRA', '3pm':'3PM', stl:'STL', blk:'BLK', min:'MIN', tov:'TOV' }[bet.statType] || '';
    const metaHtml = (betTypeLabel || statLabel) ? `<div style="display:flex;gap:5px;margin-bottom:7px;">
      ${betTypeLabel ? `<span class="stat-pill">${betTypeLabel}</span>` : ''}
      ${statLabel ? `<span class="stat-pill">${statLabel}</span>` : ''}
    </div>` : '';

    return `<div class="bet-item ${gradeClass}" id="bet-${realIdx}">
      <div class="bet-top">
        <div class="bet-text">${escHtml(bet.text)}</div>
      </div>
      ${metaHtml}
      ${tagsHtml}
      <div class="bet-date-str">${dateStr}</div>
      <div class="bet-actions">
        <div id="badge-${realIdx}">${badgeHtml}</div>
        <button class="bet-btn" onclick="gradeBet(${realIdx}, this)">GRADE</button>
        <button class="bet-btn" onclick="copyBet(${realIdx}, this)">COPY</button>
        <button class="bet-btn delete" onclick="deleteBet(${realIdx})">✕</button>
      </div>
    </div>`;
  }).join('');
}

function buildBadge(bet, i) {
  if (!bet.grade) return '';
  const pl = calcPL(bet.odds, bet.grade);
  const plStr = fmtPL(pl);
  const icon = bet.grade === 'win' ? '✓' : bet.grade === 'loss' ? '✗' : '~';
  const word = bet.grade === 'win' ? 'WIN' : bet.grade === 'loss' ? 'LOSS' : 'PUSH';
  const actualStr = bet.actual && bet.actual !== 'manual' ? ` (${bet.actual})` : '';
  return `<span class="grade-badge grade-${bet.grade}">${icon} ${word} ${plStr}${actualStr}</span>`;
}

function showManualBtns(i) {
  const el = document.getElementById(`badge-${i}`);
  if (!el) return;
  const bet = bets[i];
  const odds = bet ? bet.odds : null;
  el.innerHTML = `<div class="manual-grade-btns">
    <button class="mgb mgb-w" onclick="manualGrade(${i},'win')">W</button>
    <button class="mgb mgb-l" onclick="manualGrade(${i},'loss')">L</button>
    <button class="mgb mgb-p" onclick="manualGrade(${i},'push')">P</button>
  </div>`;
}

function manualGrade(i, result) {
  setGrade(i, result, 'manual');
}

function setGrade(i, result, actual) {
  const bet = bets[i];
  if (!bet) return;
  bet.grade = result;
  bet.actual = actual;
  saveToStorage();
  render();
}

