function parsePlay(text) {
  const statMap = {
    'points': 'pts', 'rebounds': 'reb', 'assists': 'ast',
    'points rebounds assists': 'pra', '3-pointers made': '3pm',
    'steals': 'stl', 'blocks': 'blk', 'minutes': 'min', 'turnovers': 'tov'
  };
  const ou = text.match(/\b(over|under)\s+([\d.]+)\s+(points(?:\s+rebounds\s+assists)?|rebounds|assists|3-pointers made|steals|blocks|minutes|turnovers)/i);
  if (!ou) return null;
  const direction = ou[1].toLowerCase();
  const line = parseFloat(ou[2]);
  const stat = statMap[ou[3].toLowerCase()] || ou[3].toLowerCase();
  const beforeOU = text.substring(0, text.toLowerCase().indexOf(ou[0].toLowerCase())).trim();
  const words = beforeOU.split(/\s+/);
  const norm = s => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9 ]/g,'');

  // Try matching against NBA_PLAYERS list (longest match first)
  let playerName = null, firstName = null, lastName = null;
  for (let len = Math.min(5, words.length); len >= 1; len--) {
    const candidate = words.slice(0, len).join(' ');
    const match = NBA_PLAYERS.find(p => norm(p.name) === norm(candidate));
    if (match) {
      playerName = match.name;
      const parts = match.name.split(' ');
      firstName = parts[0];
      lastName = parts.slice(1).join(' ');
      break;
    }
  }
  // Fallback: first 2 words
  if (!playerName) {
    playerName = words.slice(0, 2).join(' ');
    firstName = words[0] || '';
    lastName = words[1] || '';
  }

  return { playerName, firstName, lastName, direction, line, stat };
}

async function getBdlPlayer(parsed) {
  const norm = s => s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'').replace(/[^a-z0-9 ]/g,'');
  const headers = { 'Authorization': API_KEY };

  const trySearch = async (params) => {
    for (const base of [
      'https://api.balldontlie.io/nba/v1/players/active',
      'https://api.balldontlie.io/nba/v1/players'
    ]) {
      const res = await fetch(`${base}?${params}&per_page=25`, { headers });
      const data = await res.json();
      if (data.data && data.data.length > 0) {
        const exact = data.data.find(p =>
          norm(p.first_name) === norm(parsed.firstName) &&
          norm(p.last_name) === norm(parsed.lastName)
        );
        const partial = data.data.find(p =>
          norm(p.first_name).startsWith(norm(parsed.firstName).substring(0,3)) &&
          norm(p.last_name).startsWith(norm(parsed.lastName).substring(0,3))
        );
        const found = exact || partial || data.data[0];
        if (found) return found;
      }
    }
    return null;
  };

  let p = await trySearch(`first_name=${encodeURIComponent(norm(parsed.firstName))}&last_name=${encodeURIComponent(norm(parsed.lastName))}`);
  if (p) return p;
  p = await trySearch(`search=${encodeURIComponent(norm(parsed.lastName))}`);
  if (p) return p;
  p = await trySearch(`search=${encodeURIComponent(norm(parsed.firstName))}`);
  return p;
}

async function gradeBet(i, btn) {
  const bet = bets[i];
  if (!bet) return;
  const parsed = parsePlay(bet.text);
  if (!parsed) { showManualBtns(i); return; }

  btn.textContent = '...';
  try {
    const player = await getBdlPlayer(parsed);
    if (!player) { showManualBtns(i); btn.textContent = 'GRADE'; return; }

    const res = await fetch(
      `https://api.balldontlie.io/nba/v1/stats?player_ids[]=${player.id}&start_date=${bet.date}&end_date=${bet.date}&per_page=5`,
      { headers: { 'Authorization': API_KEY } }
    );
    const data = await res.json();
    if (!data.data || !data.data.length) { showManualBtns(i); btn.textContent = 'GRADE'; return; }

    gradeFromStats(i, data.data[0], parsed);
  } catch(e) { showManualBtns(i); }
  btn.textContent = 'GRADE';
}

function gradeFromStats(i, gameStats, parsed) {
  const statKeys = { pts:'pts', reb:'reb', ast:'ast', pra:null, '3pm':'fg3m', stl:'stl', blk:'blk', tov:'turnover' };
  let actual;
  if (parsed.stat === 'pra') {
    actual = (gameStats.pts||0) + (gameStats.reb||0) + (gameStats.ast||0);
  } else if (parsed.stat === 'min') {
    const m = gameStats.min;
    actual = m ? parseFloat(m.split(':')[0]) : null;
  } else {
    actual = gameStats[statKeys[parsed.stat] || parsed.stat];
  }
  if (actual === null || actual === undefined) { showManualBtns(i); return; }
  const result = actual === parsed.line ? 'push' : (parsed.direction === 'over' ? actual > parsed.line : actual < parsed.line) ? 'win' : 'loss';
  setGrade(i, result, actual);
}

async function gradeAll(btn) {
  if (!bets.length) return;
  btn.textContent = '⏳ Grading...';
  btn.disabled = true;
  for (let i = 0; i < bets.length; i++) {
    if (bets[i].grade) continue;
    const parsed = parsePlay(bets[i].text);
    if (!parsed) { showManualBtns(i); continue; }
    try {
      const player = await getBdlPlayer(parsed);
      if (!player) { showManualBtns(i); continue; }
      const res = await fetch(
        `https://api.balldontlie.io/nba/v1/stats?player_ids[]=${player.id}&start_date=${bets[i].date}&end_date=${bets[i].date}&per_page=5`,
        { headers: { 'Authorization': API_KEY } }
      );
      const data = await res.json();
      if (!data.data || !data.data.length) { showManualBtns(i); continue; }
      gradeFromStats(i, data.data[0], parsed);
    } catch(e) { showManualBtns(i); }
    await new Promise(r => setTimeout(r, 300));
  }
  btn.textContent = '⚡ GRADE ALL';
  btn.disabled = false;
  render();
}

// ── Helpers ──────────────────────────────────────────────────────────
function deleteBet(i) {
  bets.splice(i, 1);
  saveToStorage();
  render();
}

function copyBet(i, btn) {
  navigator.clipboard.writeText(bets[i].text).then(() => {
    btn.textContent = '✓';
    setTimeout(() => btn.textContent = 'COPY', 1500);
  });
}

function clearAllBets() {
  if (!confirm('Clear all bets?')) return;
  bets = [];
  saveToStorage();
  render();
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function formatDate(d) {
  if (!d) return '';
  const today = new Date().toISOString().split('T')[0];
  const yest  = new Date(); yest.setDate(yest.getDate()-1);
  const yStr  = yest.toISOString().split('T')[0];
  if (d === today) return 'Today';
  if (d === yStr)  return 'Yesterday';
  return new Date(d + 'T12:00:00').toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });
}
